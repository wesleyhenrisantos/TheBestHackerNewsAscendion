{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "HackerNews": {
    "BaseUrl": "https://hacker-news.firebaseio.com/v0/",
    "BestStoriesCacheMinutes": 5,
    "StoryCacheMinutes": 10,
    "TimeoutSeconds": 30,
    "MaxStoriesPerRequest": 200,
    "FetchTopIdsBuffer": 250
  }
}
